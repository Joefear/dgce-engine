@'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# IDE / editor
.vscode/
!.vscode/extensions.json
.idea/

# OS files
.DS_Store
Thumbs.db

# Local tool state
.claude/settings.local.json

# Test temp artifacts
tests/.tmp/
.test_tmp/
.pytest_tmp/

# DGCE runtime artifacts (engine root)
.dce/

# DGCE runtime artifacts in engine internals
aether_core/.dce/

# DGCE workspace artifacts (defiant-sky)
defiant-sky/.dce/*
!defiant-sky/.dce/input/
!defiant-sky/.dce/input/**

# Runtime logs / local data
.runtime/
defiant-sky/.runtime/

# Local/generated data logs
data/*.jsonl
'@ | Set-Content .gitignore.pytest_local_tmp/

