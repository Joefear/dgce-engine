{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defiantinds.com/schemas/game-adapter-stage2-preview-v1.schema.json",
  "title": "DGCEGameAdapterStage2Preview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "contract_name",
    "contract_version",
    "adapter",
    "domain",
    "source_stage0_fingerprint",
    "source_input_reference",
    "planned_changes",
    "governance_context",
    "machine_view",
    "human_view",
    "artifact_fingerprint"
  ],
  "properties": {
    "artifact_type": { "const": "game_adapter_stage2_preview" },
    "contract_name": { "const": "DGCEGameAdapterStage2Preview" },
    "contract_version": { "const": "dgce.game_adapter.stage2.preview.v1" },
    "adapter": { "const": "game" },
    "domain": { "const": "game_adapter" },
    "source_stage0_fingerprint": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "source_input_reference": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "planned_changes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/PlannedChange" }
    },
    "governance_context": { "$ref": "#/$defs/GovernanceContext" },
    "machine_view": { "type": "object" },
    "human_view": { "type": "object" },
    "resolver_context": { "$ref": "#/$defs/ResolverContext" },
    "artifact_fingerprint": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "SafeIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9_./:+#-]+$"
    },
    "Target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "target_path", "target_kind"],
      "properties": {
        "target_id": { "$ref": "#/$defs/SafeIdentifier" },
        "target_path": { "$ref": "#/$defs/SafeIdentifier" },
        "target_kind": {
          "enum": [
            "BlueprintClass",
            "CppClass",
            "ActorComponent",
            "Variable",
            "Event",
            "Binding",
            "Asset",
            "InputAction"
          ]
        }
      }
    },
    "Summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "impact", "risk", "review_focus"],
      "properties": {
        "intent": {
          "enum": [
            "add_gameplay_capability",
            "adjust_existing_behavior",
            "remove_deprecated_behavior",
            "connect_existing_systems",
            "prepare_for_review"
          ]
        },
        "impact": { "enum": ["gameplay", "ui", "data", "input", "none"] },
        "risk": { "enum": ["low", "medium", "high"] },
        "review_focus": {
          "enum": [
            "asset_scope",
            "logic_flow",
            "data_shape",
            "event_binding",
            "component_setup"
          ]
        }
      }
    },
    "PlannedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_id", "target", "operation", "domain_type", "strategy", "summary"],
      "properties": {
        "change_id": { "$ref": "#/$defs/SafeIdentifier" },
        "target": { "$ref": "#/$defs/Target" },
        "operation": { "enum": ["create", "modify", "delete"] },
        "domain_type": {
          "enum": ["Blueprint", "C++", "component", "variable", "event", "binding", "asset", "input_action"]
        },
        "strategy": { "enum": ["Blueprint", "C++", "both"] },
        "summary": { "$ref": "#/$defs/Summary" }
      }
    },
    "GovernanceContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_pack", "guardrail_required"],
      "properties": {
        "policy_pack": { "enum": ["game_adapter_stage2_preview", "game_adapter_stage2_guardrail"] },
        "guardrail_required": { "type": "boolean" }
      }
    },
    "ResolvedSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol_name", "symbol_kind", "source_path", "resolution_method", "confidence"],
      "properties": {
        "symbol_name": { "$ref": "#/$defs/SafeIdentifier" },
        "symbol_kind": {
          "enum": [
            "BlueprintClass",
            "CppClass",
            "ActorComponent",
            "Variable",
            "Event",
            "Binding",
            "Asset",
            "InputAction"
          ]
        },
        "source_path": { "$ref": "#/$defs/SafeIdentifier" },
        "resolution_method": { "const": "path_metadata" },
        "confidence": { "enum": ["exact_path_match", "candidate_match"] }
      }
    },
    "UnresolvedSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol_name", "symbol_kind", "source_path", "resolution_method", "confidence"],
      "properties": {
        "symbol_name": { "$ref": "#/$defs/SafeIdentifier" },
        "symbol_kind": {
          "enum": [
            "BlueprintClass",
            "CppClass",
            "ActorComponent",
            "Variable",
            "Event",
            "Binding",
            "Asset",
            "InputAction"
          ]
        },
        "source_path": { "type": "null" },
        "resolution_method": { "const": "path_metadata" },
        "confidence": { "const": "unresolved" }
      }
    },
    "ResolverContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolved_symbols", "unresolved_symbols"],
      "properties": {
        "resolved_symbols": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/ResolvedSymbol" }
        },
        "unresolved_symbols": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/UnresolvedSymbol" }
        }
      }
    }
  }
}
