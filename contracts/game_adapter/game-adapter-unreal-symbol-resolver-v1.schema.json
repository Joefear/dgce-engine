{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defiantinds.com/schemas/game-adapter-unreal-symbol-resolver-v1.schema.json",
  "title": "DGCEGameAdapterUnrealSymbolResolver",
  "oneOf": [
    { "$ref": "#/$defs/ResolverInputContract" },
    { "$ref": "#/$defs/ResolverOutputContract" }
  ],
  "$defs": {
    "SafeIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9_./:+#-]+$"
    },
    "SafeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./:+#-]+$"
    },
    "SymbolKind": {
      "enum": [
        "BlueprintClass",
        "CppClass",
        "ActorComponent",
        "Variable",
        "Event",
        "Binding",
        "Asset",
        "InputAction"
      ]
    },
    "RequestedTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "target_path", "target_kind"],
      "properties": {
        "target_id": { "$ref": "#/$defs/SafeIdentifier" },
        "target_path": { "$ref": "#/$defs/SafeIdentifier" },
        "target_kind": { "$ref": "#/$defs/SymbolKind" }
      }
    },
    "ResolverInputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "contract_name",
        "contract_version",
        "adapter",
        "domain",
        "source_manifest_fingerprint",
        "source_candidate_index_fingerprint",
        "allowed_symbol_kinds",
        "stage_usage"
      ],
      "oneOf": [
        { "required": ["requested_symbols"], "not": { "required": ["requested_targets"] } },
        { "required": ["requested_targets"], "not": { "required": ["requested_symbols"] } }
      ],
      "properties": {
        "artifact_type": { "const": "game_adapter_unreal_symbol_resolver_input" },
        "contract_name": { "const": "DGCEGameAdapterUnrealSymbolResolver" },
        "contract_version": { "const": "dgce.game_adapter.unreal_symbol_resolver.v1" },
        "adapter": { "const": "game" },
        "domain": { "const": "game_adapter" },
        "source_manifest_fingerprint": { "$ref": "#/$defs/SafeIdentifier" },
        "source_candidate_index_fingerprint": { "$ref": "#/$defs/SafeIdentifier" },
        "requested_symbols": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/SafeIdentifier" }
        },
        "requested_targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/RequestedTarget" }
        },
        "allowed_symbol_kinds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/SymbolKind" }
        },
        "stage_usage": { "enum": ["Stage2Preview", "Stage7Alignment", "both"] }
      }
    },
    "ResolvedSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol_name", "symbol_kind", "source_path", "resolution_method", "confidence"],
      "properties": {
        "symbol_name": { "$ref": "#/$defs/SafeIdentifier" },
        "symbol_kind": { "$ref": "#/$defs/SymbolKind" },
        "source_path": { "$ref": "#/$defs/SafeRelativePath" },
        "resolution_method": { "const": "path_metadata" },
        "confidence": { "enum": ["exact_path_match", "candidate_match"] }
      }
    },
    "UnresolvedSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol_name", "symbol_kind", "source_path", "resolution_method", "confidence"],
      "properties": {
        "symbol_name": { "$ref": "#/$defs/SafeIdentifier" },
        "symbol_kind": { "$ref": "#/$defs/SymbolKind" },
        "source_path": { "type": "null" },
        "resolution_method": { "const": "path_metadata" },
        "confidence": { "const": "unresolved" }
      }
    },
    "IntegrationContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "context_kind", "symbol_metadata_available"],
      "properties": {
        "stage": { "enum": ["Stage2Preview", "Stage7Alignment"] },
        "context_kind": { "const": "resolver_metadata" },
        "symbol_metadata_available": { "type": "boolean" }
      }
    },
    "IntegrationPoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage2_preview_context", "stage7_alignment_context"],
      "properties": {
        "stage2_preview_context": {
          "allOf": [
            { "$ref": "#/$defs/IntegrationContext" },
            { "properties": { "stage": { "const": "Stage2Preview" } } }
          ]
        },
        "stage7_alignment_context": {
          "allOf": [
            { "$ref": "#/$defs/IntegrationContext" },
            { "properties": { "stage": { "const": "Stage7Alignment" } } }
          ]
        }
      }
    },
    "ResolverOutputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "contract_name",
        "contract_version",
        "adapter",
        "domain",
        "source_input_fingerprint",
        "resolved_symbols",
        "unresolved_symbols",
        "resolution_status",
        "integration_points",
        "artifact_fingerprint"
      ],
      "properties": {
        "artifact_type": { "const": "game_adapter_unreal_symbol_resolver_output" },
        "contract_name": { "const": "DGCEGameAdapterUnrealSymbolResolver" },
        "contract_version": { "const": "dgce.game_adapter.unreal_symbol_resolver.v1" },
        "adapter": { "const": "game" },
        "domain": { "const": "game_adapter" },
        "source_input_fingerprint": { "$ref": "#/$defs/SafeIdentifier" },
        "resolved_symbols": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/ResolvedSymbol" }
        },
        "unresolved_symbols": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/UnresolvedSymbol" }
        },
        "resolution_status": {
          "enum": ["resolved", "partially_resolved", "unresolved", "input_invalid"]
        },
        "integration_points": { "$ref": "#/$defs/IntegrationPoints" },
        "artifact_fingerprint": { "type": "string", "minLength": 1 }
      }
    }
  }
}
