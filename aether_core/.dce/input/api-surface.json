{
  "section_id": "api-surface",
  "section_title": "DGCE Governed API Surface",
  "objective": "Define the complete external and internal API contract for DGCE so the system can be implemented, integrated, and productized without ambiguity.",
  "scope": {
    "include": [
      "HTTP endpoints",
      "endpoint purpose",
      "request schemas",
      "response schemas",
      "error response schemas",
      "status and next_action responses",
      "lifecycle precondition behavior",
      "idempotency expectations",
      "versioning conventions",
      "storage-independent API contracts"
    ],
    "exclude": [
      "UI design",
      "database schema internals",
      "alternative transport protocols",
      "new lifecycle stages",
      "auth platform redesign"
    ]
  },
  "context": {
    "system_name": "DGCE",
    "api_style": "JSON-over-HTTP",
    "base_path": "/api/v1/dgce",
    "required_properties": [
      "deterministic",
      "auditable",
      "governed",
      "approval-gated",
      "no silent writes",
      "clear next action",
      "model-agnostic"
    ],
    "lifecycle_stages": [
      "input",
      "preview",
      "review",
      "approval",
      "preflight",
      "gate",
      "alignment",
      "execution",
      "output"
    ]
  },
  "api_contract": {
    "resource_identity": {
      "primary_resource": "section",
      "primary_key": "section_id"
    },
    "common_request_headers": [
      {
        "name": "Content-Type",
        "required": true,
        "value": "application/json"
      },
      {
        "name": "X-Request-Id",
        "required": false,
        "type": "string"
      }
    ],
    "common_response_headers": [
      {
        "name": "Content-Type",
        "required": true,
        "value": "application/json"
      }
    ],
    "common_response_envelope": {
      "required_fields": [
        "ok",
        "operation",
        "section_id",
        "timestamp"
      ],
      "optional_fields": [
        "data",
        "error",
        "next_action",
        "warnings"
      ]
    }
  },
  "endpoints": [
    {
      "name": "create_or_update_section_input",
      "method": "PUT",
      "path": "/sections/{section_id}/input",
      "purpose": "Persist canonical section input and update source fingerprint.",
      "request_body": {
        "type": "object",
        "required": [
          "section_title",
          "objective",
          "scope",
          "context",
          "acceptance_criteria"
        ],
        "properties": {
          "section_title": "string",
          "objective": "string",
          "scope": "object",
          "context": "object",
          "expected_targets": "array[string]",
          "constraints": "array[string]",
          "acceptance_criteria": "array[string]"
        }
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "source_fingerprint",
          "input_path",
          "current_stage",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 400,
          "error_code": "invalid_section_input"
        }
      ],
      "preconditions": [],
      "idempotency": "Idempotent for identical normalized input payloads.",
      "side_effects": [
        "Writes canonical input artifact",
        "Invalidates stale downstream approvals or execution eligibility when fingerprint changes"
      ]
    },
    {
      "name": "generate_preview",
      "method": "POST",
      "path": "/sections/{section_id}/preview",
      "purpose": "Generate a governed preview artifact for the section.",
      "request_body": {
        "type": "object",
        "required": [],
        "properties": {}
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "preview_path",
          "input_fingerprint",
          "preview_status",
          "planned_tasks",
          "expected_targets",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "section_input_not_found"
        },
        {
          "status_code": 409,
          "error_code": "preview_blocked_by_invalid_input"
        }
      ],
      "preconditions": [
        "SectionInput exists and is valid"
      ],
      "idempotency": "Safe to repeat; identical valid input should yield deterministic preview output.",
      "side_effects": [
        "Writes preview artifact"
      ]
    },
    {
      "name": "submit_review",
      "method": "POST",
      "path": "/sections/{section_id}/review",
      "purpose": "Record review decision for the current preview artifact.",
      "request_body": {
        "type": "object",
        "required": [
          "review_status",
          "reviewed_by"
        ],
        "properties": {
          "review_status": "enum[approved,rejected,needs_changes]",
          "review_notes": "array[string]",
          "reviewed_by": "string"
        }
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "review_status",
          "review_path",
          "current_stage",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "preview_not_found"
        },
        {
          "status_code": 409,
          "error_code": "review_references_stale_preview"
        }
      ],
      "preconditions": [
        "Current preview artifact exists"
      ],
      "idempotency": "Not idempotent across differing review decisions; latest valid review record becomes current.",
      "side_effects": [
        "Writes review artifact"
      ]
    },
    {
      "name": "submit_approval",
      "method": "POST",
      "path": "/sections/{section_id}/approval",
      "purpose": "Record approval authorizing progression beyond review.",
      "request_body": {
        "type": "object",
        "required": [
          "approved",
          "approved_by"
        ],
        "properties": {
          "approved": "boolean",
          "approved_by": "string",
          "approval_reason": "string"
        }
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "approved",
          "approval_path",
          "approval_stale",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "review_not_found"
        },
        {
          "status_code": 409,
          "error_code": "approval_references_stale_input"
        }
      ],
      "preconditions": [
        "A valid review artifact exists"
      ],
      "idempotency": "Latest valid approval for current input fingerprint is authoritative.",
      "side_effects": [
        "Writes approval artifact"
      ]
    },
    {
      "name": "run_preflight",
      "method": "POST",
      "path": "/sections/{section_id}/preflight",
      "purpose": "Perform pre-execution readiness checks.",
      "request_body": {
        "type": "object",
        "required": [],
        "properties": {}
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "preflight_status",
          "checks",
          "all_checks_passed",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "approval_not_found"
        },
        {
          "status_code": 409,
          "error_code": "preflight_blocked_by_stale_approval"
        }
      ],
      "preconditions": [
        "Current valid approval exists"
      ],
      "idempotency": "Repeatable for unchanged inputs and environment assumptions.",
      "side_effects": [
        "Writes preflight artifact"
      ]
    },
    {
      "name": "evaluate_gate",
      "method": "POST",
      "path": "/sections/{section_id}/gate",
      "purpose": "Determine whether execution is open or blocked.",
      "request_body": {
        "type": "object",
        "required": [],
        "properties": {}
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "gate_status",
          "blocking_reasons",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "preflight_not_found"
        }
      ],
      "preconditions": [
        "Preflight has been run"
      ],
      "idempotency": "Deterministic for unchanged artifact state.",
      "side_effects": [
        "Writes execution gate record"
      ]
    },
    {
      "name": "check_alignment",
      "method": "POST",
      "path": "/sections/{section_id}/alignment",
      "purpose": "Confirm current execution attempt aligns with reviewed and approved artifacts.",
      "request_body": {
        "type": "object",
        "required": [],
        "properties": {}
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "alignment_status",
          "misalignment_reasons",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "gate_record_not_found"
        }
      ],
      "preconditions": [
        "Gate has been evaluated"
      ],
      "idempotency": "Deterministic for unchanged artifact state.",
      "side_effects": [
        "Writes alignment record"
      ]
    },
    {
      "name": "execute_section",
      "method": "POST",
      "path": "/sections/{section_id}/execute",
      "purpose": "Execute the section only when governance conditions are satisfied.",
      "request_body": {
        "type": "object",
        "required": [],
        "properties": {}
      },
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "run_id",
          "execution_status",
          "writes_attempted",
          "writes_applied",
          "writes_skipped_identical",
          "errors",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "alignment_not_found"
        },
        {
          "status_code": 409,
          "error_code": "execution_blocked_by_gate"
        },
        {
          "status_code": 409,
          "error_code": "execution_blocked_by_misalignment"
        }
      ],
      "preconditions": [
        "Gate status is open",
        "Alignment status is aligned"
      ],
      "idempotency": "Execution is governed; repeated execution against identical state must not produce silent divergent writes.",
      "side_effects": [
        "Writes execution stamp",
        "Writes or updates output artifact"
      ]
    },
    {
      "name": "get_section_status",
      "method": "GET",
      "path": "/sections/{section_id}/status",
      "purpose": "Return current lifecycle status, stale detection state, and next action.",
      "request_body": null,
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "current_stage",
          "is_stale",
          "approval_required",
          "preflight_required",
          "gate_blocked",
          "alignment_required",
          "execution_status",
          "output_status",
          "next_action"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "section_not_found"
        }
      ],
      "preconditions": [],
      "idempotency": "Read-only.",
      "side_effects": []
    },
    {
      "name": "get_section_output",
      "method": "GET",
      "path": "/sections/{section_id}/output",
      "purpose": "Return final output artifact summary for a section.",
      "request_body": null,
      "success_response": {
        "status_code": 200,
        "data_fields": [
          "section_id",
          "latest_run_id",
          "input_fingerprint",
          "output_status",
          "generated_files",
          "skipped_files",
          "validation_status",
          "next_action",
          "updated_at"
        ]
      },
      "error_responses": [
        {
          "status_code": 404,
          "error_code": "output_not_found"
        }
      ],
      "preconditions": [
        "At least one execution attempt has completed or output artifact exists"
      ],
      "idempotency": "Read-only.",
      "side_effects": []
    }
  ],
  "error_model": {
    "required_fields": [
      "ok",
      "operation",
      "section_id",
      "timestamp",
      "error"
    ],
    "error_object_fields": [
      "code",
      "message",
      "details"
    ],
    "required_error_codes": [
      "invalid_section_input",
      "section_input_not_found",
      "preview_blocked_by_invalid_input",
      "preview_not_found",
      "review_references_stale_preview",
      "review_not_found",
      "approval_references_stale_input",
      "approval_not_found",
      "preflight_blocked_by_stale_approval",
      "preflight_not_found",
      "gate_record_not_found",
      "execution_blocked_by_gate",
      "execution_blocked_by_misalignment",
      "section_not_found",
      "output_not_found"
    ]
  },
  "status_contract": {
    "required_fields": [
      "section_id",
      "current_stage",
      "is_stale",
      "approval_required",
      "preflight_required",
      "gate_blocked",
      "alignment_required",
      "execution_status",
      "output_status",
      "next_action"
    ],
    "next_action_examples": [
      "Create section input",
      "Generate preview",
      "Review preview",
      "Approve section",
      "Run preflight",
      "Resolve gate block",
      "Refresh stale input",
      "Execute section",
      "Nothing pending"
    ]
  },
  "determinism_rules": [
    "Identical normalized requests must yield identical artifact-visible results",
    "Read-only endpoints must not mutate artifacts",
    "Write endpoints must produce auditable persisted records",
    "Error responses must be structured and stable",
    "Status responses must derive from persisted artifact state rather than transient model reasoning"
  ],
  "acceptance_criteria": [
    "All lifecycle-relevant endpoints are explicitly defined",
    "Each endpoint includes request schema, success shape, error codes, and preconditions",
    "The API contract does not bypass governance stages",
    "The status endpoint exposes actionable next_action",
    "The contract is implementation-ready rather than descriptive",
    "The output can directly support route generation and API tests"
  ]
}