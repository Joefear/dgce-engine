{
  "section_id": "system-breakdown",
  "section_title": "DGCE System Breakdown and Build Graph",
  "objective": "Define DGCE as a set of concrete implementation modules with explicit responsibilities, typed inputs, typed outputs, anchored dependencies, governance touchpoints, ownership boundaries, and full build-graph dependencies so code generation can proceed without guessing.",
  "scope": {
    "include": [
      "modules and components",
      "responsibility definitions",
      "typed inputs and outputs per module",
      "inter-module data dependencies",
      "governance touchpoints",
      "failure modes",
      "file ownership boundaries",
      "build and execution order"
    ],
    "exclude": [
      "UI design",
      "high-level narrative architecture",
      "non-actionable descriptions",
      "new lifecycle stages"
    ]
  },
  "context": {
    "system_name": "DGCE",
    "core_layers": [
      "Guardrail",
      "Itera",
      "Aether",
      "DGCE Core"
    ],
    "required_properties": [
      "deterministic",
      "auditable",
      "governed",
      "modular",
      "implementation-ready"
    ]
  },
  "modules": [
    {
      "name": "SectionInputHandler",
      "layer": "DGCE Core",
      "responsibility": "Accept, normalize, validate, fingerprint, and persist section input artifacts.",
      "inputs": [
        {
          "name": "raw_section_input",
          "type": "SectionInputRequest",
          "schema_fields": [
            {
              "name": "section_id",
              "type": "string"
            },
            {
              "name": "section_title",
              "type": "string"
            },
            {
              "name": "objective",
              "type": "string"
            },
            {
              "name": "scope",
              "type": "object"
            },
            {
              "name": "context",
              "type": "object"
            },
            {
              "name": "acceptance_criteria",
              "type": "array",
              "items": "string"
            }
          ]
        }
      ],
      "outputs": [
        {
          "name": "SectionInput",
          "type": "artifact",
          "artifact_path": ".dce/input/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "section_input_validator",
          "kind": "module",
          "reference": "planner/validation.py"
        },
        {
          "name": "artifact_writer",
          "kind": "module",
          "reference": "planner/io.py"
        }
      ],
      "governance_touchpoints": [
        "input validation",
        "fingerprint generation"
      ],
      "failure_modes": [
        "invalid input structure",
        "missing required fields",
        "artifact write failure"
      ],
      "owned_paths": [
        ".dce/input/"
      ],
      "implementation_order": 1
    },
    {
      "name": "PreviewGenerator",
      "layer": "DGCE Core",
      "responsibility": "Generate deterministic preview artifacts from valid section input.",
      "inputs": [
        {
          "name": "SectionInput",
          "type": "artifact",
          "artifact_path": ".dce/input/{section_id}.json"
        }
      ],
      "outputs": [
        {
          "name": "PreviewArtifact",
          "type": "artifact",
          "artifact_path": ".dce/plans/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "decomposition_engine",
          "kind": "module",
          "reference": "planner/decompose.py"
        },
        {
          "name": "plan_renderer",
          "kind": "module",
          "reference": "planner/render.py"
        }
      ],
      "governance_touchpoints": [
        "input fingerprint validation"
      ],
      "failure_modes": [
        "invalid decomposition",
        "missing expected targets"
      ],
      "owned_paths": [
        ".dce/plans/"
      ],
      "implementation_order": 2
    },
    {
      "name": "ReviewManager",
      "layer": "DGCE Core",
      "responsibility": "Capture and validate review decisions against the current preview artifact.",
      "inputs": [
        {
          "name": "PreviewArtifact",
          "type": "artifact",
          "artifact_path": ".dce/plans/{section_id}.json"
        },
        {
          "name": "review_request",
          "type": "ReviewRequest",
          "schema_fields": [
            {
              "name": "review_status",
              "type": "enum",
              "values": [
                "approved",
                "rejected",
                "needs_changes"
              ]
            },
            {
              "name": "reviewed_by",
              "type": "string"
            },
            {
              "name": "review_notes",
              "type": "array",
              "items": "string",
              "optional": true
            }
          ]
        }
      ],
      "outputs": [
        {
          "name": "ReviewArtifact",
          "type": "artifact",
          "artifact_path": ".dce/reviews/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "artifact_writer",
          "kind": "module",
          "reference": "planner/io.py"
        }
      ],
      "governance_touchpoints": [
        "preview fingerprint validation"
      ],
      "failure_modes": [
        "stale preview reference",
        "invalid review status",
        "artifact write failure"
      ],
      "owned_paths": [
        ".dce/reviews/"
      ],
      "implementation_order": 3
    },
    {
      "name": "ApprovalManager",
      "layer": "DGCE Core",
      "responsibility": "Authorize downstream progression based on a valid review artifact.",
      "inputs": [
        {
          "name": "ReviewArtifact",
          "type": "artifact",
          "artifact_path": ".dce/reviews/{section_id}.json"
        },
        {
          "name": "approval_request",
          "type": "ApprovalRequest",
          "schema_fields": [
            {
              "name": "approved",
              "type": "boolean"
            },
            {
              "name": "approved_by",
              "type": "string"
            },
            {
              "name": "approval_reason",
              "type": "string",
              "optional": true
            }
          ]
        }
      ],
      "outputs": [
        {
          "name": "ApprovalArtifact",
          "type": "artifact",
          "artifact_path": ".dce/approvals/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "artifact_writer",
          "kind": "module",
          "reference": "planner/io.py"
        }
      ],
      "governance_touchpoints": [
        "approval gating",
        "review validation"
      ],
      "failure_modes": [
        "missing review",
        "invalid approval request",
        "artifact write failure"
      ],
      "owned_paths": [
        ".dce/approvals/"
      ],
      "implementation_order": 4
    },
    {
      "name": "StaleCheckEvaluator",
      "layer": "DGCE Core",
      "responsibility": "Evaluate whether current approval and related artifacts are stale relative to the latest section input fingerprint.",
      "inputs": [
        {
          "name": "SectionInput",
          "type": "artifact",
          "artifact_path": ".dce/input/{section_id}.json"
        },
        {
          "name": "ApprovalArtifact",
          "type": "artifact",
          "artifact_path": ".dce/approvals/{section_id}.json"
        }
      ],
      "outputs": [
        {
          "name": "StaleCheckRecord",
          "type": "artifact",
          "artifact_path": ".dce/stale/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "fingerprint_comparator",
          "kind": "module",
          "reference": "planner/validation.py"
        },
        {
          "name": "artifact_writer",
          "kind": "module",
          "reference": "planner/io.py"
        }
      ],
      "governance_touchpoints": [
        "stale input detection",
        "fingerprint comparison"
      ],
      "failure_modes": [
        "stale approval",
        "missing upstream artifact",
        "artifact write failure"
      ],
      "owned_paths": [
        ".dce/stale/"
      ],
      "implementation_order": 5
    },
    {
      "name": "PreflightChecker",
      "layer": "DGCE Core",
      "responsibility": "Run execution readiness checks only after stale-check validation.",
      "inputs": [
        {
          "name": "ApprovalArtifact",
          "type": "artifact",
          "artifact_path": ".dce/approvals/{section_id}.json"
        },
        {
          "name": "StaleCheckRecord",
          "type": "artifact",
          "artifact_path": ".dce/stale/{section_id}.json"
        }
      ],
      "outputs": [
        {
          "name": "PreflightRecord",
          "type": "artifact",
          "artifact_path": ".dce/preflight/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "preflight_validator",
          "kind": "module",
          "reference": "planner/validation.py"
        }
      ],
      "governance_touchpoints": [
        "approval validation",
        "stale-check enforcement"
      ],
      "failure_modes": [
        "failed checks",
        "stale approval",
        "missing stale-check record"
      ],
      "owned_paths": [
        ".dce/preflight/"
      ],
      "implementation_order": 6
    },
    {
      "name": "ExecutionGateEvaluator",
      "layer": "Guardrail",
      "responsibility": "Determine whether execution is allowed or blocked under policy and readiness conditions.",
      "inputs": [
        {
          "name": "PreflightRecord",
          "type": "artifact",
          "artifact_path": ".dce/preflight/{section_id}.json"
        }
      ],
      "outputs": [
        {
          "name": "ExecutionGate",
          "type": "artifact",
          "artifact_path": ".dce/execution/gate/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "guardrail_policy_engine",
          "kind": "module",
          "reference": "guardrail/scan.py"
        }
      ],
      "governance_touchpoints": [
        "policy enforcement",
        "execution blocking"
      ],
      "failure_modes": [
        "policy violation",
        "blocked execution"
      ],
      "owned_paths": [
        ".dce/execution/gate/"
      ],
      "implementation_order": 7
    },
    {
      "name": "AlignmentValidator",
      "layer": "DGCE Core",
      "responsibility": "Ensure execution aligns with reviewed, approved, and gated artifacts before task execution.",
      "inputs": [
        {
          "name": "ExecutionGate",
          "type": "artifact",
          "artifact_path": ".dce/execution/gate/{section_id}.json"
        },
        {
          "name": "ApprovalArtifact",
          "type": "artifact",
          "artifact_path": ".dce/approvals/{section_id}.json"
        },
        {
          "name": "ReviewArtifact",
          "type": "artifact",
          "artifact_path": ".dce/reviews/{section_id}.json"
        }
      ],
      "outputs": [
        {
          "name": "AlignmentRecord",
          "type": "artifact",
          "artifact_path": ".dce/execution/alignment/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "artifact_consistency_validator",
          "kind": "module",
          "reference": "planner/validation.py"
        }
      ],
      "governance_touchpoints": [
        "artifact consistency validation",
        "alignment enforcement"
      ],
      "failure_modes": [
        "misalignment",
        "stale artifacts",
        "missing upstream artifact"
      ],
      "owned_paths": [
        ".dce/execution/alignment/"
      ],
      "implementation_order": 8
    },
    {
      "name": "ExecutionEngine",
      "layer": "Aether",
      "responsibility": "Execute section tasks only after successful alignment and persist execution results.",
      "inputs": [
        {
          "name": "AlignmentRecord",
          "type": "artifact",
          "artifact_path": ".dce/execution/alignment/{section_id}.json"
        },
        {
          "name": "PreviewArtifact",
          "type": "artifact",
          "artifact_path": ".dce/plans/{section_id}.json"
        }
      ],
      "outputs": [
        {
          "name": "ExecutionStamp",
          "type": "artifact",
          "artifact_path": ".dce/execution/stamps/{section_id}.json"
        },
        {
          "name": "OutputArtifact",
          "type": "artifact",
          "artifact_path": ".dce/outputs/{section_id}.json"
        }
      ],
      "dependencies": [
        {
          "name": "task_executor",
          "kind": "module",
          "reference": "planner/execute.py"
        },
        {
          "name": "artifact_writer",
          "kind": "module",
          "reference": "planner/io.py"
        }
      ],
      "governance_touchpoints": [
        "alignment enforcement",
        "execution stamp persistence"
      ],
      "failure_modes": [
        "execution failure",
        "partial execution",
        "artifact write failure"
      ],
      "owned_paths": [
        ".dce/execution/stamps/",
        ".dce/outputs/"
      ],
      "implementation_order": 9
    }
  ],
  "build_graph": {
    "type": "directed_acyclic_graph",
    "edges": [
      [
        "SectionInputHandler",
        "PreviewGenerator"
      ],
      [
        "PreviewGenerator",
        "ReviewManager"
      ],
      [
        "ReviewManager",
        "ApprovalManager"
      ],
      [
        "ApprovalManager",
        "StaleCheckEvaluator"
      ],
      [
        "SectionInputHandler",
        "StaleCheckEvaluator"
      ],
      [
        "StaleCheckEvaluator",
        "PreflightChecker"
      ],
      [
        "ApprovalManager",
        "PreflightChecker"
      ],
      [
        "PreflightChecker",
        "ExecutionGateEvaluator"
      ],
      [
        "ExecutionGateEvaluator",
        "AlignmentValidator"
      ],
      [
        "ReviewManager",
        "AlignmentValidator"
      ],
      [
        "ApprovalManager",
        "AlignmentValidator"
      ],
      [
        "AlignmentValidator",
        "ExecutionEngine"
      ],
      [
        "PreviewGenerator",
        "ExecutionEngine"
      ]
    ]
  },
  "determinism_rules": [
    "module execution order must be deterministic",
    "all declared data dependencies must be represented in the build graph",
    "no module may execute without required inputs",
    "failure must halt downstream modules",
    "all outputs must be persisted before next stage"
  ],
  "acceptance_criteria": [
    "each module has defined responsibility, typed inputs, typed outputs, and anchored dependencies",
    "build graph is explicit, acyclic, and complete for declared module inputs",
    "implementation order is clear",
    "no module relies on implicit behavior",
    "ownership boundaries are disambiguated",
    "output is implementation-ready"
  ],
  "tests": [
    {
      "name": "SectionInputHandler rejects invalid input",
      "verifies": "SectionInputHandler",
      "assertion": "SectionInputHandler must reject inputs missing required SectionInputRequest fields and must not persist an artifact on invalid input."
    },
    {
      "name": "PreviewGenerator requires SectionInput",
      "verifies": "PreviewGenerator",
      "edge": [
        "SectionInputHandler",
        "PreviewGenerator"
      ],
      "assertion": "PreviewGenerator must not run unless a valid SectionInput artifact exists."
    },
    {
      "name": "ReviewManager rejects stale preview reference",
      "verifies": "ReviewManager",
      "edge": [
        "PreviewGenerator",
        "ReviewManager"
      ],
      "assertion": "ReviewManager must reject a review request if the referenced preview fingerprint does not match the current PreviewArtifact."
    },
    {
      "name": "ApprovalManager requires valid review",
      "verifies": "ApprovalManager",
      "edge": [
        "ReviewManager",
        "ApprovalManager"
      ],
      "assertion": "ApprovalManager must not persist approval when no valid ReviewArtifact exists."
    },
    {
      "name": "StaleCheckEvaluator blocks PreflightChecker when stale",
      "verifies": "StaleCheckEvaluator",
      "edge": [
        "StaleCheckEvaluator",
        "PreflightChecker"
      ],
      "assertion": "PreflightChecker must not run if StaleCheckRecord indicates the approval path is stale."
    },
    {
      "name": "ExecutionGateEvaluator blocks on failed preflight",
      "verifies": "ExecutionGateEvaluator",
      "edge": [
        "PreflightChecker",
        "ExecutionGateEvaluator"
      ],
      "assertion": "ExecutionGate must be blocked when PreflightRecord indicates failed checks."
    },
    {
      "name": "AlignmentValidator rejects mismatched artifacts",
      "verifies": "AlignmentValidator",
      "assertion": "AlignmentValidator must fail when reviewed, approved, and gated artifacts are not mutually consistent for the same section state."
    },
    {
      "name": "ExecutionEngine requires aligned execution state",
      "verifies": "ExecutionEngine",
      "edge": [
        "AlignmentValidator",
        "ExecutionEngine"
      ],
      "assertion": "ExecutionEngine must not run unless AlignmentRecord indicates execution is aligned."
    },
    {
      "name": "ExecutionEngine owned path boundary",
      "verifies": "ExecutionEngine",
      "assertion": "ExecutionEngine must not write outside .dce/execution/stamps/ and .dce/outputs/."
    },
    {
      "name": "Build graph completeness",
      "verifies": "build_graph",
      "assertion": "Every artifact input declared by a module must have a corresponding upstream producer edge in build_graph.edges."
    }
  ]
}